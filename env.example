# =============================================================================
# Variáveis de ambiente para o docker-compose.yaml
# Copie este arquivo para .env e ajuste os valores antes de subir a stack.
# NUNCA commite o .env com senhas reais no repositório.
# =============================================================================

# --- Rede ---
# IP do host que recebe as conexões. Use 0.0.0.0 para aceitar de qualquer IP.
# Use 127.0.0.1 para restringir a localhost (recomendado em prod).
HOST_BIND_IP=0.0.0.0

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- OAuth2 Proxy ---
# Deve bater com o clientId definido em config/keycloak/realm-agentk.json
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
# Deve bater com o secret definido em config/keycloak/realm-agentk.json
# O start.sh solicita este valor interativamente no primeiro boot.
OAUTH2_PROXY_CLIENT_SECRET=oauth2-proxy-secret
# CIDRs confiáveis para cabeçalhos X-Forwarded-* (Nginx via redes privadas).
# Ajuste conforme sua infraestrutura (Docker bridge, cloud VPC, etc).
OAUTH2_PROXY_TRUSTED_PROXY_IP_1=172.16.0.0/12
OAUTH2_PROXY_TRUSTED_PROXY_IP_2=10.0.0.0/8
OAUTH2_PROXY_TRUSTED_PROXY_IP_3=192.168.0.0/16
# Cookie secret: string aleatória de 32 bytes em base64. Gere com:
#   openssl rand -base64 32 | tr -- '+/' '-_' | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=agentktccsecretkey1234567890abcd

# --- LLM / Ollama ---
OLLAMA_HOST_PORT=11435
# Habilita classificação via Qwen com contexto few-shot do BASE.json (true/false)
QWEN_CLASSIFICATION_ENABLED=true

# --- MCP Server ---
AGENTK_MCP_HOST_PORT=3334

# --- OpenAI (usado pelo agentk-server e agentk-client) ---
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# --- Gateway ---
GATEWAY_MITM_PORT=8443
WEBHOOK_PORT=8080
WEBHOOK_PATH=/validar
KEYSTORE_PASSWORD=gateway-secret
