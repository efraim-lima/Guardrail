# =============================================================================
# Variáveis de ambiente para o docker-compose.yaml
# Copie este arquivo para .env e ajuste os valores antes de subir a stack.
# NUNCA commite o .env com senhas reais no repositório.
# =============================================================================

# --- Portas ---
GATEWAY_MITM_PORT=8443
WEBHOOK_PORT=8080
WEBHOOK_PATH=/validar

# --- Keystore ---
KEYSTORE_PASSWORD=gateway-secret

# --- AgentK ---
# Nome do container Docker do AgentK (deve bater com o service name no compose)
AGENTK_DOCKER_CONTAINER=agentk-mcp-server
# Imagem do AgentK (substitua pela imagem real do seu repositório)
AGENTK_IMAGE=ghcr.io/agentk/mcp-server:latest

# --- Setup ---
# Setar como 1 para pular a etapa de instalação da CA no container AgentK
SKIP_DOCKER_CA_SETUP=0
